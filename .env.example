# App URLs — on Vercel use https://your-deployment.vercel.app (or custom domain)
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Vercel: set in the dashboard so NextAuth accepts the deployment host (recommended)
# AUTH_TRUST_HOST=true

# Required in production: use `openssl rand -base64 32` (or similar). Min 32 characters.
AUTH_SECRET=replace-with-32-plus-char-secret
# Optional on Vercel if AUTH_SECRET is set: omit this and the app will derive it from AUTH_SECRET.
APP_ENCRYPTION_KEY=replace-with-32-plus-char-secret

# PostgreSQL — Neon: use the pooled connection string from the Neon dashboard (often includes
# "-pooler" in the host). The app enables the Neon serverless driver when the host matches *.neon.tech.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: BullMQ / background jobs (omit on Vercel unless you run Redis)
# REDIS_URL=redis://localhost:6379

# Optional: OpenAI for AI drafting / analysis features
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Google OAuth (Gmail / Google Workspace) — NOT wired yet; safe to omit for deploy.
# Create credentials: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web).
# Enable Gmail API (and consent screen) when you implement the connect flow.
# Authorized redirect URI (example for NextAuth): ${NEXTAUTH_URL}/api/auth/callback/google
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Microsoft OAuth (Outlook / Microsoft 365) — NOT wired yet; safe to omit for deploy.
# Register app: Azure Portal → Microsoft Entra ID → App registrations.
# Redirect URI example (NextAuth Azure AD): ${NEXTAUTH_URL}/api/auth/callback/azure-ad
# Use tenant "common" for multi-tenant personal + work, or your tenant GUID.
# -----------------------------------------------------------------------------
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Optional: outbound email display name
SMTP_FROM_NAME=Overlap
